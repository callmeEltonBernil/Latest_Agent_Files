        acwNotesEl.addEventListener('input', function() {
            clearTimeout(notesSaveTimeout);
            notesSaveTimeout = setTimeout(function() { persistAcwNotes(); }, 500);
        });
    }
    loadConversations(true);
    conversationsRefreshInterval = setInterval(function() { loadConversations(false); }, AUTO_REFRESH_MS);
    agentStatusRefreshInterval = setInterval(function() { syncAgentStatusFromServer(); }, STATUS_REFRESH_MS);
    slotStatusRefreshInterval = setInterval(function() { loadChatSlotStatuses(); }, STATUS_REFRESH_MS);

})();
</script>
}