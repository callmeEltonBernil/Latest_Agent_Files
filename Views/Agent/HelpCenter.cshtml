                </select>
                <button class="hcd-save-btn" onclick="hcSaveStatus()">Save Status</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {

    var AGENT_NAME     = '@agentName';
    var AGENT_INITIALS = '@agentInitials';
    var AGENT_USER_ID  = @userId;

    var allConversations = [];
    var activeTab        = 'assigned';
    var selId            = null;
    var convEnded        = false;
    var timerInterval    = null;
    var timerSeconds     = 300;
    var pollInterval     = null;
    var conversationsRefreshInterval = null;
    var participantLastMessageByConversation = {};
    var inactivityEndingRequested = false;
    var acwInterval = null;
    var acwStartByConversation = {};
    var acwManualStatusByConversation = {};
    var conversationSlotById = {};
    var notesSaveTimeout = null;
    var statusDurationInterval = null;
    var agentStatusRefreshInterval = null;
    var slotStatusRefreshInterval = null;

    var STATUS_DURATION_KEYS = ['available', 'active', 'break', 'lunch', 'eos'];
    var STATUS_DURATION_LABELS = {
        available: 'AVAILABLE',
        active: 'ACTIVE',
        break: 'BREAK',
        lunch: 'LUNCH',
        eos: 'EOS'
    };
    var statusDurationState = null;
    var statusDurationStorageKey = '';
    var selectedChatSlot = 1;
    var chatSlotStatusBySlot = { 1: 'active', 2: 'available', 3: 'available' };

    var MAX_CHAT_SECONDS = 300;
    var INACTIVITY_WARN_SECONDS = 120;
    var AUTO_REFRESH_MS = 8000;
    var MESSAGE_POLL_MS = 5000;
    var STATUS_REFRESH_MS = 10000;

    const COLS = ['#2980b9','#e67e22','#27ae60','#8e44ad','#e74c3c','#16a085','#d35400','#2c3e50'];
    function ac(n) { let h=0; for(let i=0;i<(n||'').length;i++) h=n.charCodeAt(i)+((h<<5)-h); return COLS[Math.abs(h)%COLS.length]; }
    function ini(n) { return (n||'?').split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase(); }
    function fmtDate(d) { return d ? new Date(d).toLocaleString('en-US',{month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'}) : '—'; }
    function clamp(v,min,max) { return Math.max(min,Math.min(max,v)); }
    function statusNorm(s) { return String(s || '').trim().toLowerCase(); }
    function createDurationTotals() {
        return {
            available: 0,
            active: 0,
            break: 0,
            lunch: 0,
            eos: 0
        };
    }

    function normalizeSlotStatus(status) {
        var s = statusNorm(status);
        if (s === 'inchat') return 'active';
        if (s === 'resolved') return 'resolved';
        if (s === 'acw') return 'acw';
        if (s === 'unavailable') return 'unavailable';
        if (s === 'available') return 'available';
        return 'active';
    }

    function slotStatusLabel(status) {
        var s = normalizeSlotStatus(status);
        if (s === 'active') return 'Active';
        if (s === 'available') return 'Available';
        if (s === 'unavailable') return 'Unavailable';
        if (s === 'acw') return 'ACW';
        if (s === 'resolved') return 'Resolved';
        return 'Active';
    }

    function isSelectedSlotActive() {
        var current = normalizeSlotStatus(chatSlotStatusBySlot[selectedChatSlot]);
        return current === 'active';
    }

    function getConversationIdForSlot(slotNumber) {
        var foundId = null;
        Object.keys(conversationSlotById).forEach(function(key) {
            if (conversationSlotById[key] === slotNumber) {
                foundId = parseInt(key, 10);
            }
        });
        return foundId;
    }

    function updateSelectedSlotUiControls() {
        var current = normalizeSlotStatus(chatSlotStatusBySlot[selectedChatSlot]);

        var rightSel = document.getElementById('agentStatusSelect');
        if (rightSel && ['active', 'available', 'unavailable', 'acw'].indexOf(current) >= 0) {
            rightSel.value = current;
            syncStatusIndicatorFromDropdown();
        }
    }

    function applySelectedSlotRestrictions() {
        if (!selId) return;

        var slotStatus = normalizeSlotStatus(chatSlotStatusBySlot[getSelectedChatSlot()] || 'active');
        if (slotStatus === 'active') return;

        clearInterval(timerInterval);
        timerInterval = null;

        var inputRow = document.getElementById('hccInputRow');
        var input = document.getElementById('hccChatIn');
        var endBtn = document.getElementById('hccEndBtn');
        if (inputRow) inputRow.classList.add('ended');
        if (input) input.placeholder = 'Slot status is ' + slotStatusLabel(slotStatus) + '. Set slot to Active to continue.';
        if (endBtn) { endBtn.disabled = true; endBtn.style.opacity = '.45'; }
    }

    function clearConversationSelectionView() {
        selId = null;
        convEnded = false;
        clearInterval(timerInterval); timerInterval = null;
        clearInterval(pollInterval); pollInterval = null;
        hideInactivityWarning();
        var timerEl = document.getElementById('hccTimerVal');
        if (timerEl) timerEl.textContent = '5:00';
        document.getElementById('hccEmpty').style.display = '';
        var cp = document.getElementById('hccPanel');
        if (cp) cp.style.display = 'none';
        document.getElementById('hcdEmpty').style.display = '';
        var dp = document.getElementById('hcDetailPanel');
        if (dp) dp.style.display = 'none';
    }

    function selectChatSlot(slotNumber, conversationId) {
        selectedChatSlot = slotNumber;
        updateSelectedSlotUiControls();
        if (conversationId) {
            openConversation(conversationId);
            return;
        }
        clearConversationSelectionView();
        renderList();
    }

    function loadChatSlotStatuses() {
        fetch('/Agent/GetChatSlotStatuses')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (!data || !data.success) return;
                chatSlotStatusBySlot[1] = normalizeSlotStatus(data.slot1 || 'available');
                chatSlotStatusBySlot[2] = normalizeSlotStatus(data.slot2 || 'available');
                chatSlotStatusBySlot[3] = normalizeSlotStatus(data.slot3 || 'available');
                updateSelectedSlotUiControls();
                renderList();
            })
            .catch(function() { });
    }

    function syncAgentStatusFromServer() {
        fetch('/Agent/GetAgentStatus?agentName=' + encodeURIComponent(AGENT_NAME))
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (!data || !data.success) return;

                var sel = document.getElementById('agentStatusSelect');
                var ind = document.getElementById('statusIndicator');
                if (sel && ['available', 'active', 'unavailable', 'acw'].indexOf(data.status) >= 0) {
                    sel.value = data.status;
                }
                if (ind) ind.className = 'hcd-status-indicator ' + data.status;

                var quickSel = document.getElementById('hclQuickStatusSelect');
                if (quickSel && ['available', 'break', 'lunch', 'eos'].indexOf(data.status) >= 0) {
                    quickSel.value = data.status;
                    var opt = quickSel.querySelector('option[value="' + data.status + '"]');
                    quickSel.style.color = opt ? opt.getAttribute('data-color') : '#333';
                }

                switchStatusDuration(data.status, 'agent');
                updateSelectedSlotUiControls();
            })
            .catch(function() {});
    }

    function persistSelectedSlotStatus(status) {
        var normalized = normalizeSlotStatus(status);
        var slotConversationId = getConversationIdForSlot(selectedChatSlot);

        // Empty slots must remain Available.
        if (!slotConversationId) normalized = 'available';

        // Slots with active assigned tickets should show Active.
        if (slotConversationId && normalized !== 'resolved' && normalized !== 'acw') normalized = 'active';

        chatSlotStatusBySlot[selectedChatSlot] = normalized;
        updateSelectedSlotUiControls();
        renderList();

        fetch('/Agent/UpdateChatSlotStatus', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                chatSlot: selectedChatSlot,
                status: normalized,
                conversationId: slotConversationId || selId || 0,
                agentName: AGENT_NAME,
                agentUserId: AGENT_USER_ID
            })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data && data.success) {
                chatSlotStatusBySlot[selectedChatSlot] = normalizeSlotStatus(data.status || normalized);
                updateSelectedSlotUiControls();
                renderList();
                applySelectedSlotRestrictions();
            }
        })
        .catch(function() { });
    }

    function fmtClock(totalSeconds) {
        totalSeconds = Math.max(0, totalSeconds || 0);
        var h = Math.floor(totalSeconds / 3600);
        var m = Math.floor((totalSeconds % 3600) / 60);
        var s = totalSeconds % 60;
        return (h < 10 ? '0' : '') + h + ':' + (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
    }

    function normalizeDurationStatus(status) {
        var s = statusNorm(status);
        if (s === 'inchat') return 'active';
        if (s === 'busy') return 'active';
        if (s === 'acw') return 'active';
        if (s === 'unavailable') return 'active';
        if (s === 'online') return 'available';
        if (STATUS_DURATION_KEYS.indexOf(s) >= 0) return s;
        return 'available';
    }

    function ensureDurationStateShape(state) {
        if (!state || typeof state !== 'object') state = {};
        if (!state.totals || typeof state.totals !== 'object') state.totals = createDurationTotals();
        STATUS_DURATION_KEYS.forEach(function(k) {
            if (typeof state.totals[k] !== 'number' || isNaN(state.totals[k])) state.totals[k] = 0;
        });
        if (!Array.isArray(state.logs)) state.logs = [];
        state.currentStatus = normalizeDurationStatus(state.currentStatus || 'available');
        state.currentStartMs = Number(state.currentStartMs || Date.now());
        if (isNaN(state.currentStartMs) || state.currentStartMs <= 0) state.currentStartMs = Date.now();
        return state;
    }

    function buildDurationStorageKey() {
        return 'agent-status-duration-v1:' + (AGENT_USER_ID || 0) + ':' + (AGENT_NAME || 'agent');
    }

    function loadDurationState() {
        statusDurationStorageKey = buildDurationStorageKey();
        var parsed = null;
        try {
            var raw = localStorage.getItem(statusDurationStorageKey);
            if (raw) parsed = JSON.parse(raw);
        } catch (e) { }
        statusDurationState = ensureDurationStateShape(parsed || {
            currentStatus: 'available',
            currentStartMs: Date.now(),
            totals: createDurationTotals(),
            logs: []
        });
    }

    function saveDurationState() {
        if (!statusDurationState) return;
        try {
            localStorage.setItem(statusDurationStorageKey || buildDurationStorageKey(), JSON.stringify(statusDurationState));
        } catch (e) { }
    }

    function getStatusTotalSeconds(status, nowMs) {
        if (!statusDurationState) return 0;
        var s = normalizeDurationStatus(status);
        var total = Math.floor(statusDurationState.totals[s] || 0);
        if (statusDurationState.currentStatus === s && statusDurationState.currentStartMs) {
            total += Math.max(0, Math.floor((nowMs - statusDurationState.currentStartMs) / 1000));
        }
        return total;
    }

    function renderStatusDurations() {
        if (!statusDurationState) return;
        var nowMs = Date.now();
        var current = normalizeDurationStatus(statusDurationState.currentStatus);
        var currentElapsed = Math.max(0, Math.floor((nowMs - statusDurationState.currentStartMs) / 1000));

        var currentLbl = document.getElementById('statusDurationCurrentLabel');
        var currentVal = document.getElementById('statusDurationCurrentValue');
        if (currentLbl) currentLbl.textContent = STATUS_DURATION_LABELS[current] || current.toUpperCase();
        if (currentVal) currentVal.textContent = fmtClock(currentElapsed);

        STATUS_DURATION_KEYS.forEach(function(key) {
            var val = document.getElementById('statusDurationValue-' + key);
            var card = document.getElementById('statusDurationCard-' + key);
            if (val) val.textContent = fmtClock(getStatusTotalSeconds(key, nowMs));
            if (card) card.classList.toggle('active', key === current);
        });
    }

    function switchStatusDuration(status, source) {
        source = source || 'system';
        var next = normalizeDurationStatus(status);
        if (!statusDurationState) loadDurationState();

        var quickSel = document.getElementById('hclQuickStatusSelect');
        var globalAgentStatus = statusNorm(quickSel ? quickSel.value : 'available');
        var isGlobalAway = globalAgentStatus === 'break' || globalAgentStatus === 'lunch' || globalAgentStatus === 'eos';

        if (source === 'chat' && isGlobalAway) {
            renderStatusDurations();
            return;
        }

        var nowMs = Date.now();
        var current = normalizeDurationStatus(statusDurationState.currentStatus);

        if (current === next) {
            renderStatusDurations();
            return;
        }

        var elapsed = Math.max(0, Math.floor((nowMs - statusDurationState.currentStartMs) / 1000));
        statusDurationState.totals[current] = Math.floor(statusDurationState.totals[current] || 0) + elapsed;
        statusDurationState.logs.push({
            status: current,
            startUtc: new Date(statusDurationState.currentStartMs).toISOString(),
            endUtc: new Date(nowMs).toISOString(),
            durationSeconds: elapsed
        });

        if (statusDurationState.logs.length > 1000) {
            statusDurationState.logs = statusDurationState.logs.slice(statusDurationState.logs.length - 1000);
        }

        statusDurationState.currentStatus = next;
        statusDurationState.currentStartMs = nowMs;
        saveDurationState();
        renderStatusDurations();
    }

    function initStatusDurationTracker(initialStatus) {
        loadDurationState();
        if (initialStatus) {
            switchStatusDuration(initialStatus, 'agent');
        } else {
            renderStatusDurations();
        }
        clearInterval(statusDurationInterval);
        statusDurationInterval = setInterval(function() {
            renderStatusDurations();
        }, 1000);
    }

    window.getAgentStatusDurationLogs = function() {
        if (!statusDurationState) return [];
        return (statusDurationState.logs || []).slice();
    };

    /* ── RESIZERS ─────────────────────────────────────────────── */
    function initResizers() {
        const shell = document.querySelector('.hc-shell');
        const colList = document.getElementById('hcColList');
        const colDetail = document.getElementById('hcColDetail');
        const leftHandle = document.getElementById('hcResizerLeft');
        const rightHandle = document.getElementById('hcResizerRight');
        if (!shell || !leftHandle || !rightHandle) return;

        function startDrag(onMove) {
            return function(e) {
                e.preventDefault();
                shell.classList.add('resizing');
                function move(ev) { onMove(ev); }
                function up() { shell.classList.remove('resizing'); document.removeEventListener('mousemove',move); document.removeEventListener('mouseup',up); }
                document.addEventListener('mousemove', move);
                document.addEventListener('mouseup', up);
            };
        }

        leftHandle.addEventListener('mousedown', startDrag(function(ev) {
            const r = shell.getBoundingClientRect();
            const dw = colDetail.getBoundingClientRect().width;
            colList.style.width = clamp(ev.clientX - r.left, 260, r.width - dw - 420 - 16) + 'px';
        }));

        rightHandle.addEventListener('mousedown', startDrag(function(ev) {
            const r = shell.getBoundingClientRect();
            const lw = colList.getBoundingClientRect().width;
            colDetail.style.width = clamp(r.right - ev.clientX, 240, r.width - lw - 420 - 16) + 'px';
        }));
    }

    /* ── LOAD CONVERSATIONS ───────────────────────────────────── */
    function loadConversations(initialLoad) {
        fetch('/Agent/GetConversations')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (!data.success) { showListError('Failed to load tickets.'); return; }
                allConversations = data.conversations || [];

                allConversations.forEach(function(conv) {
                    try {
                        if (conv.acwStart) {
                            var d = new Date(conv.acwStart);
                            if (!isNaN(d.getTime())) {
                                acwStartByConversation[conv.id] = d.getTime();
                                if (acwManualStatusByConversation[conv.id]) delete acwManualStatusByConversation[conv.id];
                                return;
                            }
                        }
                        if (conv.acwEnd) {
                            acwStartByConversation[conv.id] = 0;
                            if (acwManualStatusByConversation[conv.id]) delete acwManualStatusByConversation[conv.id];
                            return;
                        }
                        if (acwStartByConversation[conv.id]) delete acwStartByConversation[conv.id];
                        if (acwManualStatusByConversation[conv.id]) delete acwManualStatusByConversation[conv.id];
                    } catch (e) { }
                });

                updateStats();
                renderList();

                if (selId) {
                    var current = allConversations.find(function(c) { return c.id === selId; });
                    if (current) {
                        var mappedSlot = conversationSlotById[selId];
                        if (mappedSlot && mappedSlot >= 1 && mappedSlot <= 3) selectedChatSlot = mappedSlot;
                        updateSelectedSlotUiControls();
                        syncSelectedConversationState(current);
                        loadMessages(selId, true);
                        return;
                    }
                    selId = null;
                }

                if (initialLoad) {
                    var first = allConversations.find(function(c) { return c.isAssigned; });
                    if (first) {
                        if (!first.acwStart && !first.acwEnd) {
                            fetch('/Agent/GetConversationAcw?conversationId=' + first.id)
                                .then(function(r) { return r.json(); })
                                .then(function(d) {
                                    if (d && d.success && d.acwStart) {
                                        try { acwStartByConversation[first.id] = new Date(d.acwStart).getTime(); } catch (e) { }
                                    }
                                    openConversation(first.id);
                                })
                                .catch(function() { openConversation(first.id); });
                        } else {
                            openConversation(first.id);
                        }
                    }
                }
            })
            .catch(function() { showListError('Could not reach server.'); });
    }

    function showListError(msg) {
        document.getElementById('hclList').innerHTML =
            '<div style="padding:30px;text-align:center;color:#e24b4a;font-size:12px;">' + msg + '</div>';
    }

    function updateStats() {
        var q = allConversations.filter(function(c) { return statusNorm(c.status) !== 'resolved' && c.isAssigned; }).length;
        var r = allConversations.filter(function(c) { return statusNorm(c.status) === 'resolved' && c.isAssigned; }).length;
        document.getElementById('statQueueing').textContent = q;
        document.getElementById('statResolved').textContent = r;
    }

    /* ── FILTER & RENDER LIST ─────────────────────────────────── */
    function filtered() {
        var q = (document.getElementById('hclQ')?.value || '').toLowerCase().trim();
        var rows = allConversations.filter(function(c) {
            if (activeTab === 'assigned'   && (!c.isAssigned || statusNorm(c.status) === 'resolved')) return false;
            if (activeTab === 'unassigned' && c.isAssigned) return false;
            if (activeTab === 'resolved'   && statusNorm(c.status) !== 'resolved') return false;
            if (q && !(
                (c.question || '').toLowerCase().includes(q) ||
                (c.category || '').toLowerCase().includes(q) ||
                String(c.id).includes(q)
            )) return false;
            return true;
        });

        rows.sort(function(a, b) {
            if (activeTab === 'resolved') {
                var aSort = a.endTime ? new Date(a.endTime).getTime() : new Date(a.createdAt).getTime();
                var bSort = b.endTime ? new Date(b.endTime).getTime() : new Date(b.createdAt).getTime();
                return bSort - aSort;
            }
            if (activeTab === 'unassigned') {
                return new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime();
            }
            return new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime();
        });

        return rows;
    }

    function renderList() {
        var rows = filtered();
        var list = document.getElementById('hclList');

        if (activeTab === 'assigned') {
            var slots = rows.slice(0, 3);
            conversationSlotById = {};
            list.querySelectorAll('.hcl-card, .hcl-no-results').forEach(function(el) { el.remove(); });
            list.querySelectorAll('.hcl-slot').forEach(function(el) { el.style.display = ''; });

            for (var i = 0; i < 3; i++) {
                var conv = slots[i];
                var slotNumber = i + 1;
                var slot = document.getElementById('slot-' + slotNumber);
                if (!slot) continue;

                var isConversationActive = conv && conv.id === selId;
                var isSelectedSlot = selectedChatSlot === slotNumber;
                slot.className = 'hcl-slot' + (isConversationActive ? ' active' : '') + (isSelectedSlot ? ' selected-slot' : '') + (conv ? '' : ' empty');

                if (conv) {
                    conversationSlotById[conv.id] = slotNumber;
                    var color = ac(conv.category || 'ticket');
                    var slotState = statusNorm(conv.status) === 'resolved' ? 'resolved' : 'active';
                    chatSlotStatusBySlot[slotNumber] = slotState;
                    var slotStatus = slotStatusLabel(slotState);
                    var slotStatusClass = slotState;
                    slot.onclick = (function(id, slotNo) { return function() { selectChatSlot(slotNo, id); }; })(conv.id, slotNumber);
                    slot.innerHTML =
                        '<div class="hcl-slot-title">Chat Slot ' + slotNumber + '</div>' +
                        '<div class="hcl-slot-body">' +
                            '<div class="hcl-av" style="background:' + color + '">' + ini(conv.category) + '</div>' +
                            '<div class="hcl-body">' +
                                '<div class="hcl-row1">' +
                                    '<span class="hcl-slot-name">Ticket #' + conv.id + '</span>' +
                                    '<span class="hcl-stype ' + (conv.userType || '').toLowerCase() + '">' + (conv.userType || '—') + '</span>' +
                                '</div>' +
                                '<div class="hcl-subject">' + (conv.question || '—') + '</div>' +
                                '<div class="hcl-slot-meta">Conversation ID: ' + conv.id + '</div>' +
                            '</div>' +
                        '</div>' +
                        '<span class="hcl-slot-status ' + slotStatusClass + '">' + slotStatus + '</span>';
                } else {
                    var emptyState = 'available';
                    chatSlotStatusBySlot[slotNumber] = emptyState;
                    slot.onclick = (function(slotNo) { return function() { selectChatSlot(slotNo); }; })(slotNumber);
                    slot.innerHTML =
                        '<div class="hcl-slot-title">Chat Slot ' + slotNumber + '</div>' +
                        '<div class="hcl-slot-meta">No ticket assigned</div>' +
                        '<span class="hcl-slot-status ' + emptyState + '">' + slotStatusLabel(emptyState) + '</span>';
                }
            }
            updateSelectedSlotUiControls();
            return;
        }

        list.querySelectorAll('.hcl-slot').forEach(function(el) { el.style.display = 'none'; });
        list.querySelectorAll('.hcl-card, .hcl-no-results').forEach(function(el) { el.remove(); });

        if (!rows.length) {
            var noResultsMsg = document.createElement('div');
            noResultsMsg.className = 'hcl-no-results';
            noResultsMsg.style.cssText = 'padding:40px;text-align:center;color:#bbb;font-size:13px';
            noResultsMsg.textContent = 'No tickets found.';
            list.appendChild(noResultsMsg);
            return;
        }

        rows.forEach(function(c) {
            var isUnassigned = !c.isAssigned;
            var color = ac(c.category || 'ticket');
            var card = document.createElement('div');
            card.className = 'hcl-card' + (c.id === selId ? ' active' : '') + (isUnassigned ? ' unassigned' : '');
            card.onclick = function() { openConversation(c.id); };
            card.innerHTML =
                '<div class="hcl-av" style="background:' + color + '">' + ini(c.category) + '</div>' +
                '<div class="hcl-body">' +
                    '<div class="hcl-row1">' +
                        '<span class="hcl-name">Ticket #' + c.id + '</span>' +
                        '<span class="hcl-stype ' + (isUnassigned ? 'unassigned-badge' : (c.userType||'').toLowerCase()) + '">' +
                            (isUnassigned ? 'Unassigned' : (c.userType || '—')) +
                        '</span>' +
                    '</div>' +
                    '<div class="hcl-subject">' + (c.question || '—') + '</div>' +
                    '<div style="display:flex;align-items:center;gap:8px;margin-top:4px">' +
                        '<span class="hcl-tid">' + (c.category || '—') + ' · ' + fmtDate(c.createdAt) + '</span>' +
                    '</div>' +
                '</div>';
            list.appendChild(card);
        });
    }

    function syncSelectedConversationState(conv) {
        var isResolved = statusNorm(conv.status) === 'resolved';
        var inputRow = document.getElementById('hccInputRow');
        var input = document.getElementById('hccChatIn');
        var claimBar = document.getElementById('hccClaimBar');
        var endBtn = document.getElementById('hccEndBtn');
        var timerEl = document.getElementById('hccTimerVal');

        document.getElementById('hccMeta').textContent = conv.category + ' · ' + fmtDate(conv.createdAt);
        document.getElementById('hcdIStatus').textContent = conv.status || '—';
        applyResolveUiState(isResolved);
        document.getElementById('hcdUpdateSel').value = isResolved ? 'Resolved' : 'active';
        updateAcwState(isResolved, conv.id);

        if (!conv.isAssigned) {
            if (claimBar) claimBar.classList.remove('show');
            if (inputRow) inputRow.classList.add('ended');
            if (input) input.placeholder = 'Unassigned ticket. Waiting for admin assignment.';
            clearInterval(timerInterval); timerInterval = null;
            if (timerEl) timerEl.textContent = '5:00';
            convEnded = false;
            resetInactivityNotices();
            if (endBtn) { endBtn.disabled = true; endBtn.style.opacity = '.45'; }
            hideInactivityWarning();
            return;
        }

        if (claimBar) claimBar.classList.remove('show');

        if (isResolved) {
            convEnded = true;
            resetInactivityNotices();
            clearInterval(timerInterval); timerInterval = null;
            if (timerEl) timerEl.textContent = '0:00';
            if (inputRow) inputRow.classList.add('ended');
            if (input) input.placeholder = 'Conversation is resolved. Unresolve to reply.';
            if (endBtn) { endBtn.disabled = true; endBtn.style.opacity = '.45'; }
            hideInactivityWarning();
            return;
        }

        convEnded = false;
        if (inputRow) inputRow.classList.remove('ended');
        if (input) input.placeholder = 'Type a reply...';
        if (endBtn) { endBtn.disabled = false; endBtn.style.opacity = '1'; }
        if (!timerInterval) startTimer();
        applySelectedSlotRestrictions();
    }

    function resetInactivityNotices() { inactivityEndingRequested = false; }

    function applyResolveUiState(isResolved) {
        var topResolveBtn    = document.getElementById('hccResolveTopBtn');
        var bottomResolveBtn = document.getElementById('hccResolveBottomBtn');
        var updateSel        = document.getElementById('hcdUpdateSel');

        if (topResolveBtn)    topResolveBtn.style.display    = isResolved ? 'none' : 'flex';
        if (bottomResolveBtn) bottomResolveBtn.style.display = isResolved ? 'none' : 'flex';

        if (!updateSel) return;
        var resolvedOpt = updateSel.querySelector('option[value="Resolved"]');
        var activeOpt   = updateSel.querySelector('option[value="active"]');
        if (!resolvedOpt) return;

        resolvedOpt.hidden = false;
        resolvedOpt.disabled = false;

        if (activeOpt) {
            activeOpt.hidden   = isResolved;
            activeOpt.disabled = isResolved;
        }

        if (isResolved) updateSel.value = 'Resolved';
    }

    function updateAcwState(isResolved, conversationId) {
        var acwSection   = document.getElementById('acwSection');
        var acwNotes     = document.getElementById('acwNotes');
        var acwExpired   = document.getElementById('acwExpired');
        var acwAvailBtn  = document.getElementById('acwAvailableBtn');
        var statusSelect = document.getElementById('agentStatusSelect');
        var indicator    = document.getElementById('statusIndicator');

        if (!acwSection || !acwNotes) return;

        if (!isResolved) {
            acwSection.classList.remove('show');
            acwNotes.disabled = true;
            acwNotes.value = '';
            if (acwExpired)  acwExpired.classList.remove('show');
            if (acwAvailBtn) acwAvailBtn.disabled = false;
            clearInterval(acwInterval);
            acwInterval = null;
            if (statusSelect) {
                var acwOption = statusSelect.querySelector('option[value="acw"]');
                if (acwOption) acwOption.hidden = true;
            }
            if (conversationId) {
                delete acwStartByConversation[conversationId];
                delete acwManualStatusByConversation[conversationId];
            }
            return;
        }

        if (conversationId && acwManualStatusByConversation[conversationId] && statusSelect?.value !== 'acw') {
            acwSection.classList.remove('show');
            acwNotes.disabled = true;
            if (acwExpired) acwExpired.classList.remove('show');
            clearInterval(acwInterval); acwInterval = null;
            if (statusSelect) {
                var acwOption = statusSelect.querySelector('option[value="acw"]');
                if (acwOption) acwOption.hidden = true;
            }
            return;
        }

        acwSection.classList.add('show');
        acwNotes.disabled = false;
        if (acwExpired) acwExpired.classList.remove('show');
        if (acwAvailBtn) acwAvailBtn.disabled = false;

        if (statusSelect) {
            var acwOption = statusSelect.querySelector('option[value="acw"]');
            if (acwOption) acwOption.hidden = false;
            if (!acwManualStatusByConversation[conversationId]) statusSelect.value = 'acw';
        }
        if (indicator && !acwManualStatusByConversation[conversationId]) {
            indicator.className = 'hcd-status-indicator acw';
        }

        if (acwStartByConversation[conversationId] === 0) {
            applyAcwExpiredState();
            return;
        }

        if (!conversationId) return;

        if (!acwStartByConversation[conversationId]) {
            acwStartByConversation[conversationId] = Date.now();
        }

        startAcwTimer(conversationId);
    }

    function startAcwTimer(conversationId) {
        clearInterval(acwInterval);
        acwInterval = setInterval(function() {
            var start = acwStartByConversation[conversationId];
            if (!start) return;
            var elapsed   = Math.floor((Date.now() - start) / 1000);
            var remaining = Math.max(0, 120 - elapsed);
            updateAcwDisplay(remaining);
            if (remaining <= 0) {
                clearInterval(acwInterval); acwInterval = null;
                acwStartByConversation[conversationId] = 0;
                applyAcwExpiredState();
            }
        }, 1000);

        var start     = acwStartByConversation[conversationId];
        var elapsed   = Math.floor((Date.now() - start) / 1000);
        var remaining = Math.max(0, 120 - elapsed);
        updateAcwDisplay(remaining);
    }

    function applyAcwExpiredState() {
        var acwNotes    = document.getElementById('acwNotes');
        var acwExpired  = document.getElementById('acwExpired');
        var acwAvailBtn = document.getElementById('acwAvailableBtn');
        var statusSelect = document.getElementById('agentStatusSelect');

        if (acwNotes)   acwNotes.disabled = true;
        if (acwExpired) acwExpired.classList.add('show');
        // Keep button enabled so agent can still mark available even after expiry
        if (acwAvailBtn) acwAvailBtn.disabled = false;

        if (statusSelect) {
            var acwOption = statusSelect.querySelector('option[value="acw"]');
            if (acwOption) acwOption.hidden = true;
            if (statusSelect.value === 'acw') statusSelect.value = 'available';
        }
        syncStatusIndicatorFromDropdown();
        if (selId) hcEndAcw();
    }

    function getSelectedChatSlot() {
        if (selectedChatSlot >= 1 && selectedChatSlot <= 3) return selectedChatSlot;
        return selId ? (conversationSlotById[selId] || null) : null;
    }

    function persistChatStatus(status, conversationId) {
        if (!conversationId) return;
        fetch('/Agent/UpdateAgentStatus', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                agentName: AGENT_NAME,
                status: status,
                conversationId: conversationId,
                isChatStatus: true,
                chatSlot: getSelectedChatSlot(),
                agentUserId: AGENT_USER_ID
            })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            var slot = getSelectedChatSlot();
            if (slot) {
                chatSlotStatusBySlot[slot] = normalizeSlotStatus((data && data.status) ? data.status : status);
                updateSelectedSlotUiControls();
            }
            switchStatusDuration((data && data.status) ? data.status : status, 'chat');
            if (data && (data.acwEnded || (data.status && data.status.toLowerCase() === 'available'))) {
                try {
                    acwStartByConversation[conversationId] = 0;
                    updateAcwState(false, conversationId);
                    convEnded = false;
                    var inputRow = document.getElementById('hccInputRow');
                    if (inputRow) inputRow.classList.remove('ended');
                    var chatIn = document.getElementById('hccChatIn');
                    if (chatIn) chatIn.placeholder = 'Type a reply...';
                    var endBtn = document.getElementById('hccEndBtn');
                    if (endBtn) { endBtn.disabled = false; endBtn.style.opacity = '1'; }
                    updateStats();
                    renderList();
                } catch (e) { }
            }
        })
        .catch(function(e) { console.error('Chat status update failed:', e); });
    }

    function persistAcwNotes() {
        if (!selId) return;
        var notesEl = document.getElementById('acwNotes');
        if (!notesEl) return;
        fetch('/Agent/SaveConversationNotes', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                conversationId: selId,
                agentName: AGENT_NAME,
                chatSlot: getSelectedChatSlot(),
                notes: notesEl.value || '',
                agentUserId: AGENT_USER_ID
            })
        })
        .then(function(r) { return r.json(); })
        .catch(function(e) { console.error('Notes save failed:', e); });
    }

    function syncStatusIndicatorFromDropdown() {
        var statusSelect = document.getElementById('agentStatusSelect');
        var indicator    = document.getElementById('statusIndicator');
        if (!statusSelect || !indicator) return;
        indicator.className = 'hcd-status-indicator ' + statusSelect.value;
    }

    function updateAcwDisplay(remainingSeconds) {
        var acwTimer = document.getElementById('acwTimer');
        if (!acwTimer) return;
        var m = Math.floor(remainingSeconds / 60);
        var s = remainingSeconds % 60;
        acwTimer.textContent = m + ':' + (s < 10 ? '0' : '') + s;
    }

    // ── END ACW (I'm Available button) ────────────────────────────
    // The moment the agent presses this button is the official ACWEndTime.
    window.hcEndAcw = function() {
        if (!selId) return;

        var btn = document.getElementById('acwAvailableBtn');
        if (btn) btn.disabled = true;

        // Save notes first (best-effort, don't wait)
        persistAcwNotes();

        var conversationIdAtCall = selId;
        var slotAtCall = getSelectedChatSlot();

        fetch('/Agent/EndAcw', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                conversationId: conversationIdAtCall,
                chatSlot: slotAtCall
            })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data || !data.success) {
                if (btn) btn.disabled = false;
                alert((data && data.message) || 'Could not end ACW.');
                return;
            }

            // Stop local ACW timer
            clearInterval(acwInterval);
            acwInterval = null;
            acwStartByConversation[conversationIdAtCall] = 0;
            delete acwManualStatusByConversation[conversationIdAtCall];

            // Remove conversation from local list (slot is now free)
            allConversations = allConversations.filter(function(c) {
                return c.id !== conversationIdAtCall;
            });
            delete conversationSlotById[conversationIdAtCall];
            if (slotAtCall) chatSlotStatusBySlot[slotAtCall] = 'available';

            // Clear selection and hide panels
            selId = null;
            convEnded = false;
            clearInterval(timerInterval); timerInterval = null;
            clearInterval(pollInterval);  pollInterval  = null;

            document.getElementById('hccEmpty').style.display = '';
            var cp = document.getElementById('hccPanel');
            if (cp) cp.style.display = 'none';
            document.getElementById('hcdEmpty').style.display = '';
            var dp = document.getElementById('hcDetailPanel');
            if (dp) dp.style.display = 'none';

            // Sync quick-status dropdown to Available
            var quickSel = document.getElementById('hclQuickStatusSelect');
            if (quickSel) {
                quickSel.value = 'available';
                var availOpt = quickSel.querySelector('option[value="available"]');
                quickSel.style.color = availOpt ? availOpt.getAttribute('data-color') : '#27ae60';
            }

            updateStats();
            updateSelectedSlotUiControls();
            renderList();
        })
        .catch(function() {
            if (btn) btn.disabled = false;
            alert('Could not reach server.');
        });
    };

    window.hcSetTab = function(el, tab) {
        document.querySelectorAll('.hcl-tab').forEach(function(t) { t.classList.remove('active'); });
        el.classList.add('active');
        activeTab = tab;
        renderList();
    };
    window.hcFilter = function() { renderList(); };

    /* ── OPEN CONVERSATION ────────────────────────────────────── */
    function openConversation(id) {
        selId = id;
        var conv = allConversations.find(function(c) { return c.id === id; });
        if (!conv) return;
        var mappedSlot = conversationSlotById[id];
        if (mappedSlot && mappedSlot >= 1 && mappedSlot <= 3) selectedChatSlot = mappedSlot;
        updateSelectedSlotUiControls();
        renderList();

        document.getElementById('hccEmpty').style.display = 'none';
        var cp = document.getElementById('hccPanel');
        cp.style.display = 'flex'; cp.style.flexDirection = 'column'; cp.style.height = '100%';

        var color = ac(conv.category || 'ticket');
        var cav = document.getElementById('hccAv');
        cav.style.background = color;
        cav.textContent = ini(conv.category);
        document.getElementById('hccName').textContent = 'Ticket #' + conv.id;
        var sb = document.getElementById('hccStypeBadge');
        sb.textContent = conv.userType || '—';
        sb.className = 'hcc-stype-badge ' + (conv.userType || '').toLowerCase();
        document.getElementById('hccMeta').textContent = conv.category + ' · ' + fmtDate(conv.createdAt);

        var isResolved = statusNorm(conv.status) === 'resolved';
        applyResolveUiState(isResolved);
        updateAcwState(isResolved, conv.id);

        var statusSelect    = document.getElementById('agentStatusSelect');
        var statusIndicator = document.getElementById('statusIndicator');
        if (conv.isAssigned && !isResolved) {
            if (statusSelect)    statusSelect.value = 'inchat';
            if (statusIndicator) statusIndicator.className = 'hcd-status-indicator inchat';
            persistChatStatus('inchat', conv.id);
        }

        var claimBar = document.getElementById('hccClaimBar');
        if (!conv.isAssigned) {
            claimBar.classList.remove('show');
            document.getElementById('hccInputRow').classList.add('ended');
            document.getElementById('hccChatIn').placeholder = 'Unassigned ticket. Waiting for admin assignment.';
            var endBtnU = document.getElementById('hccEndBtn');
            if (endBtnU) { endBtnU.disabled = true; endBtnU.style.opacity = '.45'; }
        } else {
            claimBar.classList.remove('show');
            if (isResolved) {
                document.getElementById('hccInputRow').classList.add('ended');
                document.getElementById('hccChatIn').placeholder = 'Conversation is resolved. Unresolve to reply.';
            } else {
                document.getElementById('hccInputRow').classList.remove('ended');
                document.getElementById('hccChatIn').placeholder = 'Type a reply...';
            }
        }

        document.getElementById('hcdEmpty').style.display = 'none';
        var dp = document.getElementById('hcDetailPanel');
        dp.style.display = 'flex'; dp.style.flexDirection = 'column';
        document.getElementById('hcdSubj').textContent    = conv.question || '—';
        document.getElementById('hcdICat').textContent    = conv.category || '—';
        document.getElementById('hcdIType').textContent   = conv.userType || '—';
        document.getElementById('hcdIStatus').textContent = conv.status || '—';
        document.getElementById('hcdIDate').textContent   = fmtDate(conv.createdAt);
        document.getElementById('hcdReason').textContent  = conv.question || '—';
        document.getElementById('hcdUpdateSel').value     = isResolved ? 'Resolved' : 'active';

        convEnded = isResolved;
        inactivityEndingRequested = false;
        document.getElementById('hccEndBtn').disabled     = isResolved;
        document.getElementById('hccEndBtn').style.opacity = isResolved ? '.45' : '1';
        hideInactivityWarning();

        if (conv.isAssigned && !isResolved) {
            startTimer();
        } else {
            clearInterval(timerInterval); timerInterval = null;
            var timerEl = document.getElementById('hccTimerVal');
            if (timerEl) timerEl.textContent = isResolved ? '0:00' : '5:00';
        }

        applySelectedSlotRestrictions();

        loadMessages(id);

        if (pollInterval) clearInterval(pollInterval);
        pollInterval = setInterval(function() {
            if (selId === id) loadMessages(id, true);
        }, MESSAGE_POLL_MS);
    }

    /* ── LOAD / RENDER MESSAGES ───────────────────────────────── */
    function loadMessages(conversationId, silent) {
        fetch('/Agent/GetMessages?conversationId=' + conversationId)
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (!data.success) return;
                renderMessages(data.messages || [], conversationId, silent);
            })
            .catch(function() {});
    }

    function renderMessages(messages, conversationId, silent) {
        var body = document.getElementById('hccBody');
        var wasAtBottom = body.scrollHeight - body.scrollTop - body.clientHeight < 60;

        if (!silent) body.innerHTML = '';

        var existing = {};
        body.querySelectorAll('[data-msgid]').forEach(function(el) {
            existing[el.getAttribute('data-msgid')] = true;
        });

        messages.forEach(function(m) {
            if (existing[m.id]) return;
            var isAgent  = m.senderRole === 'Agent';
            var isSystem = m.senderRole === 'System';

            if (isSystem) {
                var sys = document.createElement('div');
                sys.className = 'hcc-system-msg';
                sys.setAttribute('data-msgid', m.id);
                sys.textContent = m.messageText || 'System message';
                body.appendChild(sys);
                return;
            }

            var w = document.createElement('div');
            w.className = 'hcc-msg' + (isAgent ? ' agent' : '');
            w.setAttribute('data-msgid', m.id);
            w.innerHTML =
                '<div class="hcc-msg-av" style="background:' + (isAgent ? '#1a1a2e' : ac('user')) + '">' +
                    (isAgent ? AGENT_INITIALS : 'U') +
                '</div>' +
                '<div class="hcc-msg-wrap">' +
                    '<div class="hcc-msg-name">' + (isAgent ? AGENT_NAME : (m.senderRole || 'User')) + '</div>' +
                    '<div class="hcc-msg-bub">' + escH(m.messageText) + '</div>' +
                    '<div class="hcc-msg-time">' + fmtDate(m.createdAt) + '</div>' +
                '</div>';
            body.appendChild(w);
        });

        var latestParticipantMessage = null;
        messages.forEach(function(m) {
            if (m.senderRole !== 'Agent' && m.senderRole !== 'System') {
                var dt = m.createdAt ? new Date(m.createdAt) : null;
                if (dt && !isNaN(dt.getTime())) {
                    if (!latestParticipantMessage || dt > latestParticipantMessage) latestParticipantMessage = dt;
                }
            }
        });

        if (latestParticipantMessage) {
            var previous = participantLastMessageByConversation[conversationId];
            var hadPrevious = previous instanceof Date;
            var previousMs = hadPrevious ? previous.getTime() : 0;
            var currentMs  = latestParticipantMessage.getTime();
            participantLastMessageByConversation[conversationId] = latestParticipantMessage;
            if (!hadPrevious || currentMs > previousMs) {
                inactivityEndingRequested = false;
                hideInactivityWarning();
            }
        }

        if (!silent || wasAtBottom) body.scrollTop = body.scrollHeight;
    }

    function escH(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

    /* ── SEND MESSAGE ─────────────────────────────────────────── */
    window.hcSend = function() {
        if (convEnded) return;
        if (!isSelectedSlotActive()) { alert('Selected chat slot is not Active.'); return; }
        var inp  = document.getElementById('hccChatIn');
        var text = inp.value.trim();
        if (!text || !selId) return;

        var conv = allConversations.find(function(c) { return c.id === selId; });
        if (conv && !conv.isAssigned) { alert('This ticket is unassigned.'); return; }
        if (conv && statusNorm(conv.status) === 'resolved') { alert('This conversation is resolved.'); return; }

        fetch('/Agent/SendMessage', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ conversationId: selId, messageText: text })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                inp.value = '';
                var body = document.getElementById('hccBody');
                var w = document.createElement('div');
                w.className = 'hcc-msg agent';
                w.setAttribute('data-msgid', data.id);
                w.innerHTML =
                    '<div class="hcc-msg-av" style="background:#1a1a2e">' + AGENT_INITIALS + '</div>' +
                    '<div class="hcc-msg-wrap">' +
                        '<div class="hcc-msg-name">' + AGENT_NAME + '</div>' +
                        '<div class="hcc-msg-bub">' + escH(text) + '</div>' +
                        '<div class="hcc-msg-time">Just now</div>' +
                    '</div>';
                body.appendChild(w);
                body.scrollTop = body.scrollHeight;
            } else {
                alert(data.message || 'Failed to send message.');
            }
        })
        .catch(function() { alert('Could not reach server.'); });
    };

    /* ── CLAIM ────────────────────────────────────────────────── */
    window.hcClaim = function() {
        if (!selId) return;
        fetch('/Agent/ClaimConversation', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ conversationId: selId })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                var conv = allConversations.find(function(c) { return c.id === selId; });
                if (conv) { conv.isAssigned = true; conv.agentId = AGENT_USER_ID; }
                document.getElementById('hccClaimBar').classList.remove('show');
                document.getElementById('hccInputRow').classList.remove('ended');
                if (conv && statusNorm(conv.status) !== 'resolved') {
                    convEnded = false;
                    startTimer();
                    persistChatStatus('inchat', selId);
                }
                renderList(); updateStats();
            } else {
                alert(data.message || 'Could not claim ticket.');
            }
        })
        .catch(function() { alert('Could not reach server.'); });
    };

    /* ── RESOLVE ──────────────────────────────────────────────── */
    window.hcResolve = function() {
        if (!selId) return;
        fetch('/Agent/ResolveConversation', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ conversationId: selId })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                var conv = allConversations.find(function(c) { return c.id === selId; });
                if (conv) {
                    conv.status = 'Resolved';
                    conv.endTime = data.endTime ? new Date(data.endTime).toISOString() : new Date().toISOString();
                    if (data.acwStart) {
                        try { acwStartByConversation[selId] = new Date(data.acwStart).getTime(); } catch (e) { }
                    }
                }
                document.getElementById('hcdIStatus').textContent = 'Resolved';
                applyResolveUiState(true);
                updateAcwState(true, selId);
                persistChatStatus('acw', selId);
                persistAcwNotes();
                appendSystemMsg('✓ Ticket marked as Resolved.');
                endConv();
                updateStats(); renderList();
            } else {
                alert(data.message || 'Could not resolve ticket.');
            }
        })
        .catch(function() { alert('Could not reach server.'); });
    };

    /* ── SAVE STATUS ──────────────────────────────────────────── */
    window.hcSaveStatus = function() {
        if (!selId) return;
        var newStatus = document.getElementById('hcdUpdateSel').value;
        fetch('/Agent/UpdateConversationStatus', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ conversationId: selId, status: newStatus })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.success) { alert(data.message || 'Could not update status.'); return; }

            if (data.acwStart) {
                try { acwStartByConversation[selId] = new Date(data.acwStart).getTime(); } catch (e) { }
            }

            var conv = allConversations.find(function(c) { return c.id === selId; });
            if (conv) {
                conv.status  = data.status;
                conv.endTime = statusNorm(data.status) === 'resolved' ? new Date().toISOString() : null;
            }

            document.getElementById('hcdIStatus').textContent = data.status;
            applyResolveUiState(statusNorm(data.status) === 'resolved');
            document.getElementById('hcdUpdateSel').value = statusNorm(data.status) === 'resolved' ? 'Resolved' : 'active';

            if (data.status === 'Resolved') {
                updateAcwState(true, selId);
                persistChatStatus('acw', selId);
                persistAcwNotes();
                appendSystemMsg('✓ Ticket marked as Resolved.');
                endConv();
            } else {
                acwStartByConversation[selId] = 0;
                updateAcwState(false, selId);
                persistChatStatus('inchat', selId);
                convEnded = false;
                document.getElementById('hccInputRow').classList.remove('ended');
                document.getElementById('hccChatIn').placeholder = 'Type a reply...';
                var endBtn = document.getElementById('hccEndBtn');
                if (endBtn) { endBtn.disabled = false; endBtn.style.opacity = '1'; }
                startTimer();
                if (pollInterval) clearInterval(pollInterval);
                pollInterval = setInterval(function() {
                    if (selId) loadMessages(selId, true);
                }, MESSAGE_POLL_MS);
            }

            updateStats(); renderList();
        })
        .catch(function() { alert('Could not reach server.'); });
    };

    /* ── TIMER ────────────────────────────────────────────────── */
    function startTimer() {
        clearInterval(timerInterval);
        timerSeconds = MAX_CHAT_SECONDS;
        updateTimerDisplay();
        timerInterval = setInterval(function() {
            var baseline = getInactivityBaseline();
            if (!baseline) { timerSeconds = MAX_CHAT_SECONDS; updateTimerDisplay(); return; }
            var elapsed = Math.floor((Date.now() - baseline.getTime()) / 1000);
            timerSeconds = Math.max(0, MAX_CHAT_SECONDS - elapsed);
            updateTimerDisplay();
            if (timerSeconds <= 0) { clearInterval(timerInterval); timerExpired(); }
        }, 1000);
    }

    function getInactivityBaseline() {
        if (!selId) return null;
        var conv = allConversations.find(function(c) { return c.id === selId; });
        if (!conv) return null;
        var start = conv.startTime ? new Date(conv.startTime) : null;
        if (start && isNaN(start.getTime())) start = null;
        var participant = participantLastMessageByConversation[selId];
        if (participant && !(participant instanceof Date)) participant = null;
        if (start && participant) return participant > start ? participant : start;
        return participant || start;
    }

    function updateTimerDisplay() {
        var m = Math.floor(timerSeconds/60), s = timerSeconds%60;
        var el = document.getElementById('hccTimerVal');
        var wrap = document.getElementById('hccTimer');
        if (el) el.textContent = m + ':' + (s<10?'0':'') + s;
        if (wrap) {
            wrap.classList.remove('warning','danger');
            if (timerSeconds <= 30) wrap.classList.add('danger');
            else if (timerSeconds <= 60) wrap.classList.add('warning');
        }
        checkParticipantInactivity();
    }

    function checkParticipantInactivity() {
        var conv = allConversations.find(function(c) { return c.id === selId; });
        if (!selId || convEnded || !conv || !conv.isAssigned || statusNorm(conv.status) === 'resolved') {
            hideInactivityWarning(); return;
        }
        var baseline = getInactivityBaseline();
        if (!baseline) { hideInactivityWarning(); return; }
        var inactiveSeconds = Math.floor((Date.now() - baseline.getTime()) / 1000);
        if (inactiveSeconds < INACTIVITY_WARN_SECONDS) { hideInactivityWarning(); return; }
        var remaining = MAX_CHAT_SECONDS - inactiveSeconds;
        if (remaining <= 0) {
            if (!inactivityEndingRequested) {
                inactivityEndingRequested = true;
                appendSystemMsg('⏱ Conversation ended automatically due to participant inactivity.');
                hcEndConversation();
            }
            return;
        }
        var warn = document.getElementById('hccInactiveWarn');
        if (!warn) return;
        warn.innerHTML = '<i class="fas fa-exclamation-triangle"></i> Participant inactive for ' + fmtMmSs(inactiveSeconds) + '. Auto-end in ' + fmtMmSs(remaining) + ' if no reply.';
        warn.classList.add('show');
    }

    function hideInactivityWarning() {
        var warn = document.getElementById('hccInactiveWarn');
        if (!warn) return;
        warn.classList.remove('show');
        warn.textContent = '';
    }

    function fmtMmSs(totalSeconds) {
        var m = Math.floor(totalSeconds / 60);
        var s = totalSeconds % 60;
        return m + ':' + (s < 10 ? '0' : '') + s;
    }

    function timerExpired() {
        var el = document.getElementById('hccTimerVal');
        if (el) el.textContent = '0:00';
        appendSystemMsg('⏱ Session time expired — conversation ended automatically.');
        hcEndConversation();
    }

    function endConv() {
        convEnded = true;
        clearInterval(timerInterval); timerInterval = null;
        if (pollInterval) clearInterval(pollInterval);
        hideInactivityWarning();
        var timerEl = document.getElementById('hccTimerVal');
        if (timerEl) timerEl.textContent = '0:00';
        document.getElementById('hccInputRow').classList.add('ended');
        document.getElementById('hccChatIn').placeholder = 'Conversation has ended.';
        var endBtn = document.getElementById('hccEndBtn');
        if (endBtn) { endBtn.disabled = true; endBtn.style.opacity = '.45'; }
    }

    function appendSystemMsg(text) {
        var body = document.getElementById('hccBody');
        if (!body) return;
        var d = document.createElement('div');
        d.className = 'hcc-system-msg';
        d.textContent = text;
        body.appendChild(d);
        body.scrollTop = body.scrollHeight;
    }

    window.hcEndConversation = function() {
        if (convEnded) return;
        fetch('/Agent/EndConversation', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ conversationId: selId })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                var conv = allConversations.find(function(c) { return c.id === selId; });
                if (conv) {
                    conv.status = 'Resolved';
                    conv.endTime = data.endTime ? new Date(data.endTime).toISOString() : new Date().toISOString();
                }
                document.getElementById('hcdIStatus').textContent = 'Resolved';
                applyResolveUiState(true);
                updateAcwState(true, selId);
                persistChatStatus('acw', selId);
                persistAcwNotes();
                appendSystemMsg('✓ Conversation ended by ' + AGENT_NAME + '.');
                endConv();
                updateStats(); renderList();
            } else {
                alert(data.message || 'Could not end conversation.');
            }
        })
        .catch(function() { alert('Could not reach server.'); });
    };

    /* ── AGENT STATUS ─────────────────────────────────────────── */
    window.updateAgentStatus = function() {
        var sel = document.getElementById('agentStatusSelect');
        var ind = document.getElementById('statusIndicator');
        var status = sel.value;
        ind.className = 'hcd-status-indicator ' + status;
        persistSelectedSlotStatus(status);
        var acwSection = document.getElementById('acwSection');
        if (acwSection?.classList.contains('show') && selId) {
            acwManualStatusByConversation[selId] = true;
            if (status !== 'acw') {
                acwSection.classList.remove('show');
                var acwNotes   = document.getElementById('acwNotes');
                var acwExpired = document.getElementById('acwExpired');
                if (acwNotes)   acwNotes.disabled = true;
                if (acwExpired) acwExpired.classList.remove('show');
                clearInterval(acwInterval); acwInterval = null;
                var acwOption = sel.querySelector('option[value="acw"]');
                if (acwOption) acwOption.hidden = true;
            }
        }
        if (!selId) {
            applySelectedSlotRestrictions();
            return;
        }
        var conversationIdAtCall = selId;
        fetch('/Agent/UpdateAgentStatus', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                agentName: AGENT_NAME,
                status: status,
                conversationId: conversationIdAtCall,
                isChatStatus: true,
                chatSlot: getSelectedChatSlot(),
                agentUserId: AGENT_USER_ID
            })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data || !data.success) {
                alert((data && (data.message || data.detail)) || 'Failed to update chat status.');
                return;
            }
            switchStatusDuration(data.status || status, 'chat');
            if (data.acwEnded) {
                var slotAtCall = getSelectedChatSlot();
                acwStartByConversation[conversationIdAtCall] = 0;
                delete acwManualStatusByConversation[conversationIdAtCall];
                var acwSec    = document.getElementById('acwSection');
                var acwNotes  = document.getElementById('acwNotes');
                var acwExpire = document.getElementById('acwExpired');
                if (acwSec)    acwSec.classList.remove('show');
                if (acwNotes)  acwNotes.disabled = true;
                if (acwExpire) acwExpire.classList.remove('show');
                clearInterval(acwInterval); acwInterval = null;
                var acwOpt = sel.querySelector('option[value="acw"]');
                if (acwOpt) acwOpt.hidden = true;

                allConversations = allConversations.filter(function(c) { return c.id !== conversationIdAtCall; });
                delete conversationSlotById[conversationIdAtCall];
                if (slotAtCall) chatSlotStatusBySlot[slotAtCall] = 'available';
                selId = null; convEnded = false;
                clearInterval(timerInterval); timerInterval = null;
                clearInterval(pollInterval);  pollInterval  = null;
                document.getElementById('hccEmpty').style.display = '';
                var cp = document.getElementById('hccPanel');
                if (cp) cp.style.display = 'none';
                document.getElementById('hcdEmpty').style.display = '';
                var dp = document.getElementById('hcDetailPanel');
                if (dp) dp.style.display = 'none';
                updateSelectedSlotUiControls();
                updateStats(); renderList();
            }
        })
        .catch(function() { alert('Could not reach server while updating chat status.'); });
    };

    syncAgentStatusFromServer();

    window.hcAttach = function() { alert('Attach — connect to your file upload endpoint.'); };

    /* ── QUICK STATUS ─────────────────────────────────────────── */
    window.updateQuickStatus = function() {
        var sel = document.getElementById('hclQuickStatusSelect');
        if (!sel) return;
        var status = sel.value;
        var hasActive = allConversations.some(function(c) {
            return c.isAssigned && c.status && c.status.toLowerCase() === 'active';
        });
        if (hasActive && status !== 'available') {
            alert('Cannot change agent status while a conversation is Active.');
            sel.value = 'available';
            var availOpt = sel.querySelector('option[value="available"]');
            sel.style.color = availOpt ? availOpt.getAttribute('data-color') : '#27ae60';
            return;
        }
        var selectedOption = sel.options[sel.selectedIndex];
        var color = selectedOption.getAttribute('data-color') || '#333';
        sel.style.transition = 'color 0.3s ease';
        sel.style.color = color;

        fetch('/Agent/UpdateAgentStatus', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ agentName: AGENT_NAME, status: status, isChatStatus: false, agentUserId: AGENT_USER_ID })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data || !data.success) {
                console.error('Quick status update rejected:', data);
                return fetch('/Agent/UpdateAgentStatusDirect?status=' + encodeURIComponent(status)
                    + '&agentUserId=' + encodeURIComponent(AGENT_USER_ID)
                    + '&agentName=' + encodeURIComponent(AGENT_NAME), { method: 'POST' });
            }
            switchStatusDuration(data.status || status, 'agent');
            return null;
        })
        .then(function(r) {
            if (!r) return null;
            return r.json().then(function(directData) {
                if (directData && directData.success) {
                    switchStatusDuration(directData.status || status, 'agent');
                }
                return directData;
            });
        })
        .catch(function(e) { console.error('Quick status update failed:', e); });
    };

    (function() {
        var sel = document.getElementById('hclQuickStatusSelect');
        if (sel) {
            var selectedOption = sel.options[sel.selectedIndex];
            var color = selectedOption.getAttribute('data-color') || '#333';
            sel.style.transition = 'color 0.3s ease';
            sel.style.color = color;
            sel.addEventListener('change', function() { sel.style.transition = 'color 0.3s ease'; });
            sel.addEventListener('mouseenter', function() { sel.style.transform = 'translateY(-1px)'; sel.style.boxShadow = '0 2px 6px rgba(0,0,0,.08)'; });
            sel.addEventListener('mouseleave', function() { sel.style.transform = 'translateY(0)'; });
        }
    })();

